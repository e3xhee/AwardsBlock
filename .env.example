# Shared
NODE_ENV=development

# API
API_PORT=4000
DATABASE_URL=file:./data/awardblock.sqlite
SESSION_COOKIE_NAME=awardblock_session
SESSION_SECRET=replace-with-a-long-random-string
INVITE_TOKEN_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# Web
VITE_API_BASE_URL=http://localhost:4000
VITE_CHAIN_ID=31337
VITE_RPC_URL=http://127.0.0.1:8545
# Optional. Example: https://explorer.sepolia.mantle.xyz
VITE_BLOCK_EXPLORER_URL=
VITE_REGISTRY_CONTRACT_ADDRESS=
VITE_MOCK_USDC_ADDRESS=
# Optional local browser E2E mock wallet. Use only local Anvil/test private keys.
VITE_ENABLE_DEV_WALLET=false
VITE_DEV_WALLET_PRIVATE_KEY=

# Browser E2E runner
AWARDBLOCK_CHROME_PATH=
AWARDBLOCK_CDP_PORT=9333
AWARDBLOCK_WEB_URL=http://localhost:5173
AWARDBLOCK_API_URL=http://localhost:4000

# Contracts
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
# Optional. Mirrored to VITE_BLOCK_EXPLORER_URL by contracts:sync-env
BLOCK_EXPLORER_URL=
DEPLOYMENT_BROADCAST_FILE=
REGISTRY_CONTRACT_ADDRESS=
MOCK_USDC_ADDRESS=
PRIVATE_KEY=
